{
  "name": "k-ui-monorepo",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "description": "Кометум — монорепо UI-библиотеки. Пакет публикуется из packages/core (@ii11ii11ii/k-ui).",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm -w packages/core run build",
    "dev": "npm -w packages/core run dev",
    "type-check": "npm -w packages/core run type-check",
    "publish:lib": "npm -w packages/core publish",
    "story": "histoire dev",
    "story:build": "histoire build"
  },
  "devDependencies": {
    "@histoire/plugin-vue": "^0.17.17",
    "@vitejs/plugin-vue": "^5.0.0",
    "histoire": "^0.17.17",
    "sass": "^1.77.0",
    "vite": "^5.2.0",
    "vue": "^3.4.0"
  }
}

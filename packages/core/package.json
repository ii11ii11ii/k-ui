{
  "name": "@ii11/k-ui",
  "version": "0.4.0",
  "description": "Кометум — Vue 3 UI-библиотека: компоненты, композаблы, директивы, иконки и токены тем (светлая/тёмная, плотность, акценты).",
  "type": "module",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ii11ii11ii/k-ui.git",
    "directory": "packages/core"
  },
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "files": [
    "dist",
    "src/styles"
  ],
  "module": "./dist/k-ui.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/k-ui.js"
    },
    "./style.css": "./dist/style.css",
    "./scss": "./src/styles/index.scss",
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "type-check": "vue-tsc --noEmit",
    "prepack": "npm run build"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "sass": "^1.77.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vite-plugin-dts": "^3.9.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}
